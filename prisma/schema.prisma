datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  name      String
  username  String    @unique
  email     String?   @unique
  password  String
  role      String    @default("CASHIER") // ADMIN, MANAGER, CASHIER
  permissions Json?
  license   License?  @relation(fields: [licenseId], references: [id])
  licenseId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  devices   Device[]
  orders    Order[]
  activities UserActivity[]
}

model License {
  id          String   @id @default(uuid())
  key         String   @unique
  maxDevices  Int      @default(1)
  expiryDate  DateTime
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED, BLOCKED
  users       User[]
  devices     Device[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Device {
  id           String   @id @default(uuid())
  deviceId     String   @unique // Hardware fingerpint / Browser ID
  name         String?
  authorized   Boolean  @default(false)
  lastLogin    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?
  license      License? @relation(fields: [licenseId], references: [id])
  licenseId    String?
  createdAt    DateTime @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
}

model Product {
  id             String         @id @default(uuid())
  name           String
  barcode        String?        @unique
  category       Category?      @relation(fields: [categoryId], references: [id])
  categoryId     String?
  brand          String?
  purchasePrice  Float
  sellingPrice   Float
  mrp            Float          @default(0)
  gstRate        Float          @default(0)
  stockQuantity  Float          @default(0)
  unit           String         @default("pcs")
  supplier       String?
  image          String?
  supplierId     String?        // New strict reference
  is_active      Boolean        @default(true)
  
  // Restaurant-specific fields
  foodType       String?        @default("VEG") // VEG, NON-VEG, EGG
  availability   Boolean        @default(true)
  variants       Json?          // Array of {name: string, price: number}
  addons         Json?          // Array of {name: string, price: number}
  preparationTime Int?          @default(15)
  kitchenDept    String?        @default("MAIN_KITCHEN")
  recipe         Json?          // Array of {rawMaterialId: string, quantity: number}

  orderItems       OrderItem[]
  purchaseItems    PurchaseItem[]
  salesReturnItems    SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  inventoryLogs       InventoryLog[]
  purchaseOrderItems  PurchaseOrderItem[] // New PO relation
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Supplier {
  id            String         @id @default(uuid())
  name          String
  phone         String?        @unique
  email         String?
  gstNo         String?
  address       String?
  openingBalance Float         @default(0)
  is_active     Boolean        @default(true)
  purchases     Purchase[]
  purchaseReturns PurchaseReturn[]
  purchaseOrders PurchaseOrder[]
  payments      PurchasePayment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PurchaseOrder {
  id            String         @id @default(uuid())
  poNumber      String         @unique
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId    String?
  supplierName  String?        // Legacy / Manual string
  subtotal      Float
  taxTotal      Float
  totalDiscount Float          @default(0)
  grandTotal    Float
  status        String         @default("PENDING") // PENDING, CONVERTED, CANCELLED
  expectedDate  DateTime?
  date          DateTime       @default(now())
  poItems       PurchaseOrderItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model PurchaseOrderItem {
  id              String         @id @default(uuid())
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId String
  product         Product        @relation(fields: [productId], references: [id])
  productId       String
  quantity        Float
  price           Float
  discount        Float          @default(0)
  discountPercent Float          @default(0)
  taxAmount       Float
  total           Float
}

model Customer {
  id               String   @id @default(uuid())
  name             String
  phone            String?  @unique
  email            String?
  loyaltyPoints    Int      @default(0)
  totalSpent       Float    @default(0)
  lastPurchaseDate DateTime?
  creditBalance    Float    @default(0)
  orders           Order[]
  salesReturns     SalesReturn[]
  is_active        Boolean  @default(true)
  isSynced         Boolean  @default(false)
  serverId         String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Order {
  id                    String      @id @default(uuid())
  invoiceNo             String      @unique
  billNo                Int?
  customer              Customer?   @relation(fields: [customerId], references: [id])
  customerId            String?
  subtotal              Float
  discount              Float       @default(0)
  taxTotal              Float
  grandTotal            Float
  savings               Float       @default(0)
  roundedTotal          Float       @default(0)
  amountPaid            Float       @default(0)
  balance               Float       @default(0)
  loyaltyPointsEarned   Int         @default(0)
  loyaltyPointsRedeemed Int         @default(0)
  paymentMode           String      
  orderType             String      @default("Walk-in")
  status                String      @default("COMPLETED")
  
  // Restaurant-specific fields
  waiterName            String?
  tableName             String?
  tableId               String?
  notes                 String?
  parcelCharge          Float       @default(0)
  deliveryCharge        Float       @default(0)
  shiftId               String?
  kotCount              Int         @default(0)

  orderItems            OrderItem[]
  payments              Payment[]
  salesReturns          SalesReturn[]
  isSynced              Boolean     @default(false)
  serverId              String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  creator               User?       @relation(fields: [creatorId], references: [id])
  creatorId             String?

  @@index([createdAt])
}

model SalesReturn {
  id            String            @id @default(uuid())
  returnNo      String            @unique
  order         Order?            @relation(fields: [orderId], references: [id])
  orderId       String?
  customer      Customer?         @relation(fields: [customerId], references: [id])
  customerId    String?
  subtotal      Float
  taxTotal      Float
  totalAmount   Float
  reason        String?
  status        String            @default("COMPLETED")
  returnItems   SalesReturnItem[]
  date          DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model SalesReturnItem {
  id            String      @id @default(uuid())
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id])
  salesReturnId String
  product       Product     @relation(fields: [productId], references: [id])
  productId     String
  quantity      Float
  price         Float
  taxAmount     Float
  total         Float

  @@index([salesReturnId])
  @@index([productId])
}

model OrderItem {
  id         String  @id @default(uuid())
  order      Order   @relation(fields: [orderId], references: [id])
  orderId    String
  product    Product @relation(fields: [productId], references: [id])
  productId  String
  quantity   Float
  price      Float
  mrp        Float   @default(0)
  discount   Float   @default(0)
  taxAmount Float
  total     Float

  // Restaurant-specific fields
  notes      String?
  variant    String?
  modifiers  Json?

  @@index([orderId])
  @@index([productId])
}

model PurchaseReturn {
  id           String               @id @default(uuid())
  returnNo     String               @unique
  purchase     Purchase?            @relation(fields: [purchaseId], references: [id])
  purchaseId   String?
  supplier     Supplier?            @relation(fields: [supplierId], references: [id])
  supplierId   String?
  supplierName String?
  subtotal     Float
  taxTotal     Float
  totalAmount  Float
  reason       String?
  status       String               @default("COMPLETED")
  returnItems  PurchaseReturnItem[]
  date         DateTime             @default(now())
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
  purchaseReturnId String
  product          Product        @relation(fields: [productId], references: [id])
  productId        String
  quantity         Float
  price            Float
  taxAmount        Float
  total            Float

  @@index([purchaseReturnId])
  @@index([productId])
}

model InventoryLog {
  id         String   @id @default(uuid())
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  type       String   
  quantity   Float
  reason     String?
  createdAt  DateTime @default(now())

  @@index([productId])
}

model Payment {
  id            String   @id @default(uuid())
  order         Order    @relation(fields: [orderId], references: [id])
  orderId       String
  method        String   
  amount        Float
  transactionId String?
  status        String   @default("SUCCESS")
  createdAt     DateTime @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Purchase {
  id            String         @id @default(uuid())
  invoiceNo     String         @unique
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId    String?
  supplierName  String?
  subtotal      Float
  taxTotal      Float
  totalDiscount Float          @default(0)
  grandTotal    Float
  amountPaid    Float          @default(0)
  balanceDue    Float          @default(0)
  paymentMode   String         @default("CASH")
  paymentStatus String         @default("PAID") // PAID, PARTIAL, PENDING
  status        String         @default("COMPLETED")
  date            DateTime       @default(now())
  purchaseItems   PurchaseItem[]
  purchaseReturns PurchaseReturn[]
  payments        PurchasePayment[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PurchasePayment {
  id            String    @id @default(uuid())
  purchase      Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  supplierId    String?
  method        String    @default("CASH") // CASH, UPI, CARD, BANK
  amount        Float
  transactionId String?
  date          DateTime  @default(now())
  createdAt     DateTime  @default(now())
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  purchaseId String
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  quantity   Float
  price      Float
  discount   Float    @default(0)
  discountPercent Float @default(0)
  taxAmount  Float
  total      Float
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model UserActivity {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String   // LOGIN, LOGOUT
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// RESTAURANT SPECIFIC MODELS

model TableSection {
  id        String   @id @default(uuid())
  name      String   @unique
  tables    Table[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id                 String        @id @default(uuid())
  number             String        @unique
  capacity           Int
  status             String        @default("FREE") // FREE, OCCUPIED, RESERVED, CLEANING, BILLING
  sectionId          String?
  section            TableSection? @relation(fields: [sectionId], references: [id])
  currentOrderId     String?       // Reference to active running Order ID
  runningOrderAmount Float         @default(0)
  occupiedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model KOT {
  id           String      @id @default(uuid())
  kotNo        String      @unique
  orderId      String?     // Associated running or completed Order ID
  tableId      String?
  tableName    String?
  waiterName   String?
  orderType    String      // Dine-in, Takeaway, Delivery, etc.
  status       String      @default("PENDING") // PENDING, PREPARING, READY, SERVED, CANCELLED
  items        KOTItem[]
  reprintCount Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model KOTItem {
  id           String      @id @default(uuid())
  kotId        String
  kot          KOT         @relation(fields: [kotId], references: [id], onDelete: Cascade)
  productId    String
  name         String
  quantity     Float
  notes        String?
  variant      String?
  modifiers    Json?       // Modifiers details: [{name: string, price: number}]
  status       String      @default("PENDING") // PENDING, PREPARING, READY, SERVED, CANCELLED
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Shift {
  id                  String    @id @default(uuid())
  cashierId           String
  cashierName         String
  status              String    @default("OPEN") // OPEN, CLOSED
  openingTime         DateTime  @default(now())
  closingTime         DateTime?
  openingCash         Float
  cashSales           Float     @default(0)
  upiSales            Float     @default(0)
  cardSales           Float     @default(0)
  creditSales         Float     @default(0)
  expenses            Float     @default(0)
  refunds             Float     @default(0)
  discounts           Float     @default(0)
  expectedClosingCash Float     @default(0)
  actualClosingCash   Float?
  differenceAmount    Float?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model RestaurantSettings {
  id                 String   @id @default("settings")
  name               String   @default("JUDE'S KITCHEN")
  logo               String?
  address            String   @default("DHOTTAPPANKULAM,SULTHAN BATHERY,WAYANAD")
  phone              String   @default("+91 89431 21110")
  gstin              String?
  currency           String   @default("INR")
  gstRate            Float    @default(0)
  parcelCharge       Float    @default(0)
  deliveryCharge     Float    @default(0)
  printerSize        String   @default("80mm") // 58mm, 80mm
  maxDiscountPercent Float    @default(10)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RawMaterial {
  id                String   @id @default(uuid())
  name              String   @unique
  unit              String   // kg, gram, litre, ml, pcs
  stockQuantity     Float    @default(0)
  lowStockThreshold Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  purchases         RawMaterialPurchaseItem[]
  wastage           WastageEntry[]
}

model RawMaterialPurchase {
  id           String   @id @default(uuid())
  invoiceNo    String   @unique
  supplierName String?
  totalAmount  Float
  date         DateTime @default(now())
  items        RawMaterialPurchaseItem[]
  createdAt    DateTime @default(now())
}

model RawMaterialPurchaseItem {
  id              String             @id @default(uuid())
  purchaseId      String
  purchase        RawMaterialPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  rawMaterialId   String
  rawMaterialName String
  quantity        Float
  price           Float
  total           Float
  rawMaterial     RawMaterial        @relation(fields: [rawMaterialId], references: [id])
}

model WastageEntry {
  id              String      @id @default(uuid())
  rawMaterialId   String
  rawMaterialName String
  quantity        Float
  reason          String?
  date            DateTime    @default(now())
  createdAt       DateTime    @default(now())
  rawMaterial     RawMaterial @relation(fields: [rawMaterialId], references: [id])
}
